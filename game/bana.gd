extends Node2D
class_name Bana
# T6.1 — 바나 NPC (밤 무대 그레이박스 자리 + 대사).
#
# 목적: 밤 경비·손님 응대(나라카 바)를 쥔 바나를 밤 무대에 배치하고, 말 걸면 대사를
#       들려준다. 회색 박스만(ADR-0001). 초상화 일러스트는 Phase 2.
#
# 설계 메모:
#   - miho.gd·mel.gd·okja.gd와 같은 결: 자기 몸(16×32 회색 자리)을 _draw로 그리고,
#     대사는 자기가 든다(ADR-0005: 서사 텍스트는 캐릭터에만). DialogueBox는 누가 말하든
#     모르는 순수 진행기라 — 여기 lines()가 그 출처다(미호·멜·옥자와 같은 박스를 쓴다).
#   - 위치(어느 칸에 서 있나)·언제 보이나(밤에만)는 main이 소유한다(TILE 규격·시각도
#     main 것). main이 밤 무대 칸 중앙으로 position을 맞추고, 밤 창에만 드러내며(미호
#     출퇴근·옥자 상주 station 패턴), 상호작용 대상 판정도 main의 BANA_NIGHT_TILE로 한다.
#   - 뱀파이어(혈귀) 그레이박스(CONTEXT '바나': 박쥐·검은고양이 사역마·고딕 드레스·흡혈):
#     미호(따뜻한 노랑)·멜(청록)·옥자(어두운 보라)와 한눈에 구분되게 어두운 핏빛 기조 +
#     모티프 암시(박쥐 날개 깃·고딕 드레스·창백한 얼굴·붉은 눈). 회색 기조는 유지.
#   - 톤은 어둡고 날선 밤의 결(밝은 미호·시크 건조한 멜과 또 다르다). 바나는 남들 잘 때
#     깨어 밤을 지키는 경비라(ADR-0010: 밤 경비·손님 응대 루프) 대사에 그 역할과 밤·흡혈
#     모티프를 깐다. 속죄 테마(ADR-0004: 살아선 밤의 침입자[주거침입·흡혈] → 죽어선 밤을
#     지키는 경비)는 가볍게 암시하되, '봉인된 죄목의 사실'(바나=옥자를 밤에 본 '목격'
#     조각)은 절대 안 푼다 — 그 깊이는 호감도 ♡4+에서 열리는 T6.2의 몫이다(미호 T3.3·멜
#     T5.2와 대칭, 메인 플롯 비의존, ADR-0005: 봉인 죄목의 *존재*만 암시·폭로 X).
#   - 바나는 밤 루프 담당 NPC지 함께 싸우는 액션 동료가 아니다(ADR-0010 #1) — 막기는
#     플레이어가 하고 바나는 보호 곱셈기다. 그 곱셈기·호감도는 T6.2~T6.5의 몫이고, 여기선
#     배치 + 대사 텍스트박스만 한다(T6.1 범위 — 그레이박스 최소, ADR-0006).
#   - 하트별 대사 분기(♡2–3 속죄·♡4+ '목격' 조각 떡밥)는 T6.2에서 채운다. 지금은 인트로
#     한 묶음만 — lines() 시그니처는 미호·멜과 같이 두어(hearts·first_today) T6.2가 분기만
#     얹게 한다(현재는 모든 단계가 인트로로 떨어진다).

const BODY_SIZE := Vector2(16, 32)  # NPC 자리 규격(ADR-0003, 플레이어·미호·멜·옥자와 동일)

# 하트 0~1(인트로): 어둡고 날선 밤의 결로 소개 + 역할(밤 경비·나라카 바) + 가벼운 속죄
# 암시(밤의 침입자 → 밤의 수호). 넷째 줄이 속죄 한 토막(살아선 남의 밤에 침입·피를 봤다
# → 이젠 밤을 지킨다)이되, 바나=옥자 '목격' 조각(봉인 죄목)은 ♡4+ T6.2로 봉인.
# PackedStringArray() 생성자는 상수식이 아니라 const로 못 두므로, 상수식인 배열
# 리터럴로 두고 lines()에서 PackedStringArray로 변환해 넘긴다(miho.gd·mel.gd·okja.gd 동일).
const LINES_INTRO := [
	"…낮것이 이 시간에 깨어 있군. 난 바나. 밤이 내 시간이야.",
	"남들 잘 때 난 깬다. 나라카 바를 열고, 밤에 기어드는 잡귀를 쫓는 게 내 일이지.",
	"낮의 셋과 날 같이 보지 마. 난 어울리려고 여기 선 게 아니야 — 지키려고 선 거다.",
	"살아선… 남의 밤에 함부로 들었어. 잠긴 문을 넘고, 피를 봤지. 지금은 반대야.",
	"밤이 오면 바로 와. 같이 싸우자는 게 아니라 — 네가 막고, 난 네 등을 받쳐줄 뿐이니까.",
]

# 오늘 이미 일일 대화를 한 뒤 또 말 걸었을 때(점수 없음 — 대사만 가볍게 바뀐다).
# T6.2에서 일일 대화 게이팅이 붙으면 이 줄이 쓰인다(지금은 first_today가 늘 true라 미사용).
const LINE_AGAIN := "할 말은 아까 했다. 밤은 기니까, 또 보겠지."

# 대화창에 띄울 이름.
func display_name() -> String:
	return "바나"

# 말 걸었을 때 들려줄 대사 줄들. hearts = 현재 하트 단계, first_today = 오늘 첫 대화인가
# (miho.gd·mel.gd와 같은 시그니처). T6.2가 ♡2–3 속죄·♡4+ '목격' 조각 분기를 여기 얹는다.
# T6.1에선 호감도 노드가 아직 없어 main이 인자 없이 부르고, 모든 단계가 인트로로 떨어진다.
func lines(hearts: int = 0, first_today: bool = true) -> PackedStringArray:
	if not first_today:
		return PackedStringArray([LINE_AGAIN])
	return PackedStringArray(LINES_INTRO)

func _draw() -> void:
	# 몸체: 발치 원점 기준 위로 16×32. 어두운 핏빛(고딕 드레스)으로 미호·멜·옥자와 구분.
	var body := Rect2(-BODY_SIZE.x * 0.5, -BODY_SIZE.y, BODY_SIZE.x, BODY_SIZE.y)
	draw_rect(body, Color(0.34, 0.14, 0.20))
	# 얼굴(창백한 혈귀 톤) 약간 밝게
	var top := -BODY_SIZE.y
	draw_rect(Rect2(body.position + Vector2(0, 4), Vector2(BODY_SIZE.x, 8)), Color(0.74, 0.70, 0.74))
	# 붉은 눈 암시: 얼굴에 작은 핏빛 점 두 개(흡혈귀 모티프)
	draw_rect(Rect2(-4, top + 6, 2, 2), Color(0.80, 0.16, 0.18))
	draw_rect(Rect2(2, top + 6, 2, 2), Color(0.80, 0.16, 0.18))
	# 박쥐 날개 암시: 머리 위 양옆으로 뻗은 검은 박쥐 깃(옥자 마녀모자·멜 관모와 대비되는
	# 양쪽으로 펼친 날개 실루엣 — CONTEXT '바나' 박쥐 사역마 모티프).
	draw_rect(Rect2(-8, top - 1, 3, 2), Color(0.10, 0.07, 0.09))
	draw_rect(Rect2(5, top - 1, 3, 2), Color(0.10, 0.07, 0.09))
