extends RefCounted
class_name SoulMemory
# T3.5 — 사연 한 줄(Flavor Memory): 작물 = 저승 영혼의 생전 사연 한 줄 데이터.
#
# 목적: ROADMAP T3.5 — "수확할 때마다 그 영혼의 생전 사연 한 줄(플레이버 텍스트)이
#       팝업으로 표시된다"의 그 문장들을 한 곳에 모은다(CONTEXT '사연 한 줄' =
#       Flavor Memory, 텍스트 한 줄로 세계관 깊이를 더하는 저비용 장치).
#
# 설계 메모:
#   - crops.gd(CropCatalog)·foxfire.gd(Foxfire)와 같은 결: 세이브 상태가 아니라
#     "정적 참조 데이터"다. 작물 id마다 가능한 사연 묶음을 들고 있고, 자체 상태는
#     없다(어느 줄을 봤는지 같은 진척은 호출 쪽이 카운터로 관리 — main). 그래서 씬
#     노드가 아니라 static const + class_name으로 어디서든 SoulMemory.line(id, n).
#   - ADR-0005 경계: 메인 서사 텍스트(플레이어의 미결의 죄·옥자 인연)는 캐릭터에만
#     붙는다. 사연 한 줄은 그 메인 서사가 아니라 작물이 된 '이름 없는 영혼들'의
#     가벼운 세계관 양념이다 — 미호 같은 캐릭터 속죄 서사와도 분리된, 메인 플롯에
#     의존하지 않는 자기완결 장치(독립 완성 원칙). 그래서 데이터를 캐릭터가 아니라
#     작물 쪽(이 파일)에 둔다.
#   - 작물별 톤은 CONTEXT '저승 작물' 정의를 따른다:
#       혼령초    — 푸르게 빛나는 영혼 풀(소박·무명·잔잔한 삶).
#       피안화    — 저승을 상징하는 붉은 꽃(이별·기다림·못다 한 인사).
#       영혼 호박 — 얼굴이 비치는 호박(핼러윈·축제·장난기). CONTEXT 예시도 여기.
#   - 선택은 결정적이다: line(id, index)가 index를 줄 수로 나눈 나머지로 고른다.
#     난수를 쓰지 않으므로 헤드리스 단위검증이 재현 가능하고, 호출 쪽(main)이
#     작물별 수확 횟수를 index로 넘기면 수확마다 다음 사연으로 순환한다.
#   - 그레이박스 기준 텍스트다. 분량·문체 다듬기는 후속(Phase 2 폴리시).

# 작물 id → 그 영혼의 생전 사연 묶음. 키는 CropCatalog의 영문 id와 같다.
const MEMORIES := {
	CropCatalog.HONRYEONGCHO: [
		"이 영혼은 생전에 길가의 풀꽃 이름을 모두 알았다고 한다.",
		"이 영혼은 생전에 늘 누군가의 뒤를 조용히 따라 걷던 사람이었다.",
		"이 영혼은 생전에 작은 텃밭 하나를 평생 가꾸었다고 한다.",
		"이 영혼은 생전에 비 온 뒤의 흙냄새를 가장 좋아했다.",
		"이 영혼은 생전에 이름을 남기지 못했지만, 봄마다 푸르게 돌아온다.",
	],
	CropCatalog.PIANHWA: [
		"이 영혼은 생전에 끝내 부치지 못한 편지를 한 통 품고 있었다.",
		"이 영혼은 생전에 강 건너편의 누군가를 오래도록 기다렸다고 한다.",
		"이 영혼은 생전에 헤어진 이의 이름을 붉게 새기고 떠났다.",
		"이 영혼은 생전에 마지막 인사를 하지 못한 것을 가장 후회했다.",
		"이 영혼은 생전에 붉은 노을 아래에서 약속 하나를 남겼다.",
	],
	CropCatalog.YEONGHON_HOBAK: [
		"이 영혼은 생전에 핼러윈을 가장 좋아했다고 한다.",
		"이 영혼은 생전에 동네 아이들에게 사탕을 잔뜩 나눠주던 사람이었다.",
		"이 영혼은 생전에 가장 무서운 분장으로 매년 일등을 했다고 한다.",
		"이 영혼은 생전에 호박등 안에 작은 소원을 적어 넣곤 했다.",
		"이 영혼은 생전에 축제의 마지막 불꽃까지 지켜보던 사람이었다.",
	],
}

# ── 조회 ──────────────────────────────────────────────────────────────────
# 그 작물에 등록된 사연 줄 수. 없는 id면 0(line()의 나눗셈 가드와 짝).
static func count(crop_id: String) -> int:
	return MEMORIES[crop_id].size() if MEMORIES.has(crop_id) else 0

# 사연 한 줄을 결정적으로 고른다. index를 줄 수로 나눈 나머지로 골라 순환한다
# (음수 index도 안전하게 양수 나머지로 보정). 사연이 없는 id면 ""(표시 생략 신호).
static func line(crop_id: String, index: int) -> String:
	var n := count(crop_id)
	if n <= 0:
		return ""
	return MEMORIES[crop_id][posmod(index, n)]
