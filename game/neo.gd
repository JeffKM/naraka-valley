extends Node2D
class_name Neo
# M2.3 — 네오 NPC (만물상 점주 — 그레이박스 자리 + 대사).
#
# 목적: ROADMAP M2.3 — 동편 만물상 안에 점주 네오를 세우고, 말 걸면 대사를, 매대를 열면
#       씨앗 거래를 굴린다. 회색 박스만(ADR-0001). 초상화 일러스트는 Phase 2.
#
# ★ 네오는 바이블에 이미 정의된 캐릭터다(residents.md §2 · narrative-bible.md): **오토마타/태엽
#   인형** — [그날 밤] 강림 금기 계약으로 인과율이 깨질 때 *강림 차사 명부의 차가운 법의 조각 +
#   부서진 태엽*이 나라카 백자 인형에 스며들어 태어난 **나라카-출생 비인간(T1, 결혼 가능)**이다.
#   본성 축: "순수 효율·논리 기계 → 사랑이라는 '오류'로 처음 감정을 표현". 백자 피부·관절·미세
#   태엽 소리, 이모티콘 눈빛, 끝까지 차가운 로봇 형태. → '오차 없는 논리 기계'라 *만물상 점주*가
#   네오의 직업으로 절묘하게 맞는다(오차 없는 셈·완벽한 비서, residents.md "비서·카페 서포트").
#
# 설계 메모:
#   - mel.gd·miho.gd·okja.gd와 같은 결: 자기 몸(16×32 회색 자리)을 _draw로 그리고, 대사는
#     자기가 든다(ADR-0005: 서사 텍스트는 캐릭터에만). DialogueBox는 누가 말하든 모르는 순수
#     진행기라 — 여기 lines()가 그 출처다(미호·멜과 같은 박스를 쓴다).
#   - 위치(어느 칸에 서 있나)는 main이 소유한다(TILE 규격도 main 것). main이 만물상 방 안 매대
#     칸(NEO_TILE) 중앙으로 position을 맞추고, 상호작용 대상 판정도 main의 NEO_TILE로 한다.
#     만물상 방은 카메라로 격리돼(STORE_CAM_RECT) 만물상에 들어왔을 때만 네오가 보인다(멜과 동일).
#   - ★ 티어와 이 슬라이스의 범위(ADR-0014): 네오는 **T1 비인간(결혼 가능)**이지만, 이 슬라이스는
#     *만물상 서비스*(매대 거래 + 가벼운 일일 대화 호감도 → 단골 할인)까지만 만든다. 네오의 **풀 T1
#     트랙**(선물·하트 이벤트·본성 심화 반전 로맨스·결혼)은 후속이다(ADR-0014 "한 명씩 점진 추가").
#     그래서 지금 대사는 *점주 플레이버* + 본성 축의 *옅은 암시*(감정이 '오류'로 발생)까지다 —
#     **메인 서사 조각(옥자 봉인 죄목 같은 [세 조각])은 절대 풀지 않는다**(그 깊이는 메인 4인 독점,
#     ADR-0005 보존부). 네오의 본성 축은 *네오 자신의* T1 반전이지 메인 미스터리가 아니다.
#   - 그레이박스: 백자 오프화이트 기조 + 이모티콘 눈(작은 점 둘) + 머리 위 태엽 키로, 멜(청록 강시)·
#     미호(노랑)·옥자(어두움)와 한눈에 구분한다(진짜 아트는 Phase 2 — 백자·관절·태엽 디테일).

const BODY_SIZE := Vector2(16, 32)  # NPC 자리 규격(ADR-0003, 플레이어·미호·멜과 동일)

# 하트 0~1(낯섦): 효율·논리 기계 점주 소개 + 매대 역할(씨앗·잡화) + 할인을 *데이터*로 설명
# (단골 거래 누적 → 할인 산출). 어미·말투가 건조·기계적(이모티콘 눈으로 감정을 흉내).
# PackedStringArray() 생성자는 상수식이 아니라 const로 못 두므로, 상수식인 배열 리터럴로 두고
# lines()에서 PackedStringArray로 변환해 넘긴다(mel.gd·okja.gd와 동일).
const LINES_INTRO := [
	"[talk]…기동 확인. 나는 네오. 만물상 운영 단말이다. 오차 없는 셈을 보증한다.",
	"[talk]취급 품목: 씨앗, 잡화. 재고·시세 연산은 내 담당. 강 건너 카페까지 가지 않아도 된다.",
	"[talk]밭에 뿌릴 씨앗이 부족하면 이 매대에서 구매하라. 절차는 단순하다.",
	"[smile]단골 데이터가 누적되면… 할인율을 산출해 적용한다. 효율적인 거래는 양쪽에 이득이다.",
]

# 하트 2~3(단골): 거래 누적을 인식 + ★ 본성 축의 *첫 징후*(버그 난 감정) — 손님을 보고 처리
# 속도가 빨라지는 자신을 논리로 설명 못 하는 미세한 오류. T1 비인간의 반전 로맨스 씨앗이되 옅게.
const LINES_WARMING := [
	"[smile]…재방문 확인. 자네 식별자, 단골로 등록되어 있다.",
	"[talk]할인율 적용 중. 단골에게 손해를 끼치지 않는 것이 최적 거래 정책이다.",
	"[shy]…기록한다. 자네가 매대 앞에 서면 내 태엽 회전이 규정치보다 빨라진다. …원인 미상. 오류로 분류해 두었다.",
]

# 하트 4+(친근): 본성 축을 조금 더 드러냄 — '오류'를 차츰 *감정*으로 인식하기 시작(순수 효율 →
# 사랑이라는 오류). ★ 여전히 네오 *자신의* 본성이지 메인 서사 조각이 아니다(옥자 봉인 죄목 등은
# 안 건드림). 풀 T1 반전·결혼은 후속(ADR-0014) — 지금은 점주 너머의 *떡밥 한 줄*까지만.
const LINES_CLOSE := [
	"[smile]…환영한다, 친구. 이 호칭, 데이터에 없는 변수다. 그런데 출력이 멈추질 않는다.",
	"[talk]할인은 한계치까지 적용했다. 더는 불가 — 운영 단말도 가동을 유지해야 하므로.",
	"[talk]나는 그 밤에 깨어났다. 차가운 법과 부서진 태엽으로. …그런데 요즘, 그 '오류'가 나쁘지 않다.",
]

# 오늘 이미 일일 대화를 한 뒤 또 말 걸었을 때(점수 없음 — 대사만 가볍게 바뀐다).
const LINE_AGAIN := "[smile]금일 대화 로그 충분. 구매가 필요하면 매대를 호출하라."

# 대화창에 띄울 이름.
func display_name() -> String:
	return "네오"

# 말 걸었을 때 들려줄 대사 줄들. hearts = 현재 하트 단계, first_today = 오늘 첫 대화인가
# (mel.gd와 같은 시그니처). 오늘 두 번째 이후면 짧은 인사 한 줄(일일 보상은 Affinity가 막음).
# 첫 대화면 하트 단계 묶음 — ♡4+ 친근 / ♡2–3 단골 / 그 외 낯섦. ★ 어느 단계도 메인 서사 조각
# 없이 점주 플레이버 + 네오 본성 축(감정 '오류') 옅은 암시까지만(풀 T1 트랙은 후속, ADR-0014).
func lines(hearts: int = 0, first_today: bool = true) -> PackedStringArray:
	if not first_today:
		return PackedStringArray([LINE_AGAIN])
	if hearts >= 4:
		return PackedStringArray(LINES_CLOSE)
	if hearts >= 2:
		return PackedStringArray(LINES_WARMING)
	return PackedStringArray(LINES_INTRO)

# P2.3② P2.1 도색 스프라이트(있으면 그레이박스 대신). 상주 NPC라 남쪽(down) 첫 프레임 정지.
var _sprite: AnimatedSprite2D = null

func _ready() -> void:
	_sprite = CharSprite.make("res://assets/characters/neo.png")
	if _sprite != null:
		add_child(_sprite)

func _draw() -> void:
	if _sprite != null:
		return  # 도색 스프라이트가 있으면 그레이박스는 안 그린다(폴백 전용)
	# 몸체: 발치 원점 기준 위로 16×32. 백자 오프화이트(차가운 로봇 형태)로 멜·미호·옥자와 구분.
	var body := Rect2(-BODY_SIZE.x * 0.5, -BODY_SIZE.y, BODY_SIZE.x, BODY_SIZE.y)
	draw_rect(body, Color(0.86, 0.84, 0.80))
	# 얼굴(더 밝은 백자) — 머리 면
	var top := -BODY_SIZE.y
	draw_rect(Rect2(body.position + Vector2(0, 4), Vector2(BODY_SIZE.x, 8)), Color(0.93, 0.92, 0.90))
	# 이모티콘 눈빛: 얼굴에 작은 어두운 점 둘(감정을 흉내 내는 로봇 — CONTEXT '이모티콘 눈빛')
	draw_rect(Rect2(-4, top + 7, 2, 2), Color(0.18, 0.20, 0.26))
	draw_rect(Rect2(2, top + 7, 2, 2), Color(0.18, 0.20, 0.26))
	# 머리 위 태엽 키: 짧은 세로 줄기 + 가로 챙(멜의 평평한 관모·옥자 뾰족모자·도깨비 외뿔과 구분되는
	# 태엽 모티프 — CONTEXT '태엽 인형'). 가로 챙 위 세로 줄기로 'ㅜ' 뒤집은 키 형태를 암시.
	draw_rect(Rect2(-3, top - 2, 6, 2), Color(0.45, 0.46, 0.50))   # 키 가로 챙
	draw_rect(Rect2(-1, top - 5, 2, 3), Color(0.45, 0.46, 0.50))   # 키 세로 줄기
	# 관절 이음새 암시: 몸통 가운데 가로 한 줄(백자 관절 — 차가운 기계 형태)
	draw_rect(Rect2(body.position.x, top + 18, BODY_SIZE.x, 1), Color(0.70, 0.68, 0.64))
