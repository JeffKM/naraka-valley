; 나라카 밸리 — 게임 본체 프로젝트 (Phase 1 Sprint 1에서 시작)
; T1.2: 내부해상도 320×180을 정수배(×2/×3/×4)로만 스케일하는 픽셀아트 뷰포트.
; 픽셀 규격은 ADR-0003, 그레이박스 원칙은 ADR-0001을 따른다.
;
; 에디터 UI로 편집하는 게 안전하지만(자동 생성 값 다수),
; 이 파일은 T1.2 뷰포트 설정을 명시적으로 기록하기 위해 직접 작성했다.

config_version=5

[application]

config/name="Naraka Valley"
config/description="저승 컨셉카페 세계관의 스타듀밸리형 게임 (게임 본체)"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[display]

; 내부(게임) 해상도 = 320×180 (16:9, ADR-0003)
window/size/viewport_width=320
window/size/viewport_height=180
; 시작 창 크기 = ×4 = 1280×720 (ADR-0003 권장 정수배)
window/size/window_width_override=1280
window/size/window_height_override=720
window/size/resizable=true
; 320×180 뷰포트를 통째로 렌더한 뒤 확대 → 가장 순수한 픽셀아트 룩
window/stretch/mode="viewport"
; 비율 유지(남는 공간은 레터박스). 가로/세로 비뚤어짐 방지
window/stretch/aspect="keep"
; ★핵심★ 정수배(×2/×3/…)로만 스케일. 1.5배 같은 분수배 금지 → 픽셀 뭉개짐 차단
window/stretch/scale_mode="integer"

[rendering]

; 텍스처 필터 기본값 = Nearest(보간 끔). 픽셀이 흐려지지 않게 함
textures/canvas_textures/default_texture_filter=0
; 2D 좌표를 픽셀 격자에 스냅 → 서브픽셀 흔들림 방지
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
